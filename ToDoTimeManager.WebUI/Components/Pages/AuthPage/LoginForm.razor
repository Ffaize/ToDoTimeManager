@using System.ComponentModel.DataAnnotations
@using ToDoTimeManager.WebUI.Components.Shared
@using ToDoTimeManager.WebUI.Models.Enums.Button
@using ToDoTimeManager.WebUI.Models.Enums.Input
@inherits BaseComponent

<div class="form-eyebrow">@Localizer["SIGN IN"] · @Localizer["STEP"] 1</div>
<h1 class="form-title">@Localizer["Welcome back, smith."]</h1>
<p class="form-sub">@Localizer["New to TaskForge?"] <a @onclick="OnCreateAccountClicked">@Localizer["Create an account"]</a> · @Localizer["takes 30s."]</p>
    
<div class="auth-field">
    <label class="field-label">@Localizer["Email or username"]</label>
    <Input Placeholder="email@emil.com"
           Style="@InputStyle.Default"
           Type="email"
           @bind-Value="Email"
           IconPosition="InputIconPosition.Left"
           Disabled="@IsLoading">
        <Icon>
            <EmailIcon IconSize="16"/>
        </Icon>
    </Input>
</div>

<div class="auth-field">
    <label class="field-label">@Localizer["Password"]</label>
    <Input Placeholder="password"
           Style="@InputStyle.Default"
           Type="email"
           @bind-Value="Password"
           IconPosition="InputIconPosition.Left"
           IsPassword="true"
        Disabled="@IsLoading">
        <Icon>
            <LockIcon IconSize="16" />
        </Icon>
    </Input>
</div>

<CheckInput @bind-Value="KeepSignedIn"
            Text="@Localizer["Keep me signed in"]"
            AdditionalCssClass="auth-check-input" 
            Disabled="@IsLoading" />
            
<Button Disabled="@IsLoading"
        OnClick="@OnSignInClicked"
        IsLoading="@IsLoading"
        UseLoading="true"
        Style="@ButtonStyle.Primary"
        IconPosition="ButtonIconPosition.Right"
        Text="@Localizer["Strike the anvile"]">
    <Icon>
        <ArrowRightIcon IconSize="14"/>
    </Icon>
</Button>

<div class="footer-line">
    @Localizer["Trouble signing in?"] <a href="#">@Localizer["Contact your forge admin"]</a>
</div>