@using ToDoTimeManager.WebUI.Components.Shared
@inherits BaseComponent
<div class="auth-page__form @AditionalCssClass">
    <div class="form-panel">
        <div class="brand-row">
            <div class="brand-logo">
            </div>
            <span class="brand-name">Task<span>Forge</span></span>
        </div>
        
        <div class="anvil-stage">
            <div class="anvil-glow"></div>
            @MainIcon
        </div>
        
        <div>
            <div class="tagline">
                @MainText
            </div>
            <div class="tagline-sub">
                @SubText
            </div>
            <StepsComponent Steps="@Steps" CurrentStep="@CurrentStep"/>
        </div>
    </div>

    <div class="form-wrap">
        @FormContent
    </div>
</div>
