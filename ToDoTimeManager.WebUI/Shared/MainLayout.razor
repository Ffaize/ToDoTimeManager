@using ToDoTimeManager.WebUI.Components.Shared
@using ToDoTimeManager.WebUI.Components.Toast
@using ToDoTimeManager.WebUI.Components.Modals
@inherits LayoutComponentBase
@inject NavigationManager NavigationManager

<PageTitle>ToDoTimeManager.WebUI</PageTitle>
<ToastBox/>
<ModalContainer/>

<AuthorizeView>
    <Authorized>
        <div class="page">
            <div class="sidebar">
                <NavMenu CollapseNavMenu="ColapseNavMenu" CollapseNavMenuChanged="OnCollapseNavMenuChanged"/>
            </div>

            <main @onclick="HideNavMenu">
                <article class="content px-4">
                    <div class="page-container">
                        @Body
                    </div>
                </article>
            </main>
        </div>
    </Authorized>
    <Authorizing>
        @* <Loader IsLoading="true"/> *@
    </Authorizing>

    <NotAuthorized>
        <RedirectToLogin/>
    </NotAuthorized>
</AuthorizeView>

@code {
    public bool ColapseNavMenu { get; set; }

    private void HideNavMenu()
    {
        ColapseNavMenu = true;
        StateHasChanged();
    }

    private void OnCollapseNavMenuChanged(bool obj)
    {
        ColapseNavMenu = obj;
        StateHasChanged();
    }
}
