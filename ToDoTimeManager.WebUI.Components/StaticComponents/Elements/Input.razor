@using ToDoTimeManager.WebUI.Models.Enums.Input

<div class="input-shell @GetStyleClass() @GetValidationClass() @AdditionalCssClass">
    @if (Icon is not null && IconPosition == InputIconPosition.Left)
    {
        @Icon
    }
    <input type="@GetInputType()"
           value="@Value"
           placeholder="@Placeholder"
           disabled="@Disabled"
           autocomplete="off"
           @oninput="HandleInput"
           @onfocusout="HandleFocusOut" />
    @if (Icon is not null && IconPosition == InputIconPosition.Right)
    {
        @Icon
    }
    @if (IsPassword)
    {
        <button type="button" class="eye-btn" @onclick="ToggleVisibility">
            @if (_showPassword)
            {
                <EyeSlashIcon />
            }
            else
            {
                <EyeFillIcon />
            }
        </button>
    }
    @if (HasValidationError)
    {
        <div class="input-error-bubble">@Localizer[_validationMessage]</div>
    }
</div>