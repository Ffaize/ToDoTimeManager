@using ToDoTimeManager.WebUI.Models.Enums.Button
<button class="btn @GetStyleClass() @AdditionalCssClass" @onclick="OnClick" disabled="@Disabled">
    @if (UseLoading && IsLoading)
    {
        <span class="spinner-border spinner-border-sm" role="status" aria-hidden="true"></span>
    }
    else
    {
        @if (Icon is not null && IconPosition == ButtonIconPosition.Left)
        {
            <span class="btn__icon btn__icon--left">@Icon</span>
        }
        @if (!string.IsNullOrEmpty(Text))
        {
            <span class="btn__text">@Text</span>
        }
        @if (Icon is not null && IconPosition == ButtonIconPosition.Right)
        {
            <span class="btn__icon btn__icon--right">@Icon</span>
        }
    }
</button>

@code {

    [Parameter] public string? AdditionalCssClass { get; set; }
    [Parameter] public EventCallback OnClick { get; set; }
    [Parameter] public bool Disabled { get; set; }
    [Parameter] public string? Text { get; set; }
    [Parameter] public RenderFragment? Icon { get; set; }
    [Parameter] public ButtonIconPosition IconPosition { get; set; } = ButtonIconPosition.Right;
    [Parameter] public ButtonStyle Style { get; set; } = ButtonStyle.Primary;
    [Parameter] public bool UseLoading { get; set; }
    [Parameter] public bool IsLoading { get; set; }

    private string GetStyleClass()
    {
        return Style switch
        {
            ButtonStyle.Primary => "btn-primary",
            ButtonStyle.Secondary => "btn-secondary",
            ButtonStyle.Ghost => "btn-ghost",
            _ => string.Empty
        };
    }

}
