@using ToDoTimeManager.WebUI.Models.Enums.Button
@inherits ToDoTimeManager.WebUI.Components.BaseComponents.BaseComponent

<div class="form-eyebrow">@Localizer["TWO-FACTOR_UPPER"] · @Localizer["STEP"] 2</div>
<div>
    <h1 class="form-title">@Localizer["Light the forge."]</h1>
    <p class="form-sub">
        <span>@Localizer["We sent a 6-digit ember code to"]</span>
        <strong>@Email</strong>
        <span>@Localizer["Drop it in below to seal the session."]</span>
    </p>
</div>

<div class="otp-row with-dash" id="otp-inputs">
    <input class="otp-cell @GetIsFilledCssClass(0)" type="text" maxlength="1" autocomplete="off" value="@OtpValues[0]" @oninput="e => HandleInput(e, 1)">
    <input class="otp-cell @GetIsFilledCssClass(1)" type="text" maxlength="1" autocomplete="off" value="@OtpValues[1]" @oninput="e => HandleInput(e, 2)">
    <input class="otp-cell @GetIsFilledCssClass(2)" type="text" maxlength="1" autocomplete="off" value="@OtpValues[2]" @oninput="e => HandleInput(e, 3)">
    <span class="otp-dash">
        <span>—</span>
    </span>
    <input class="otp-cell @GetIsFilledCssClass(3)" type="text" maxlength="1" autocomplete="off" value="@OtpValues[3]" @oninput="e => HandleInput(e, 4)">
    <input class="otp-cell @GetIsFilledCssClass(4)" type="text" maxlength="1" autocomplete="off" value="@OtpValues[4]" @oninput="e => HandleInput(e, 5)">
    <input class="otp-cell @GetIsFilledCssClass(5)" type="text" maxlength="1" autocomplete="off" value="@OtpValues[5]" @oninput="e => HandleInput(e, 6)">
</div>

<div class="meta-row">
    <span class="timer">
        <span>@Localizer["CODE EXPIRES IN"] </span>
        <strong>@FormattedTime</strong>
    </span>
    <button type="button" class="resend" @onclick="OnResendCodeClicked" disabled="@IsLoading">
        @Localizer["Resend code"]
    </button>
</div>

<Button Disabled="@(IsButtonDisabled)"
        OnClick="@OnVerifyClicked"
        IsLoading="@IsLoading"
        UseLoading="true"
        Style="@ButtonStyle.Primary"
        IconPosition="ButtonIconPosition.Right"
        Text="@Localizer["Verify code"]">
    <Icon>
        <ArrowRightIcon IconSize="14" />
    </Icon>
</Button>


<div class="hint">
    <TimerIcon IconSize="14" />
    <div>
        <strong>
            <span>@Localizer["Email not in your inbox?"]</span>
        </strong>
        <span>@Localizer["Check your spam folder or sender filters for "]</span>
        <code>
            <span>@SessionState?.SenderEmail</span>
        </code>
        <span>@Localizer[". The code is single-use and expires in 5 minutes."]</span>
    </div>
</div>

<div class="helper-row">
    <a @onclick="OnUseDifferentEmailClicked" @onclick:preventDefault href="#">
        <span>@Localizer["Use a different email"]</span>
    </a>
    <a href="mailto:dmitro.danko@gmail.com?subject=Звернення до адміна">
        <span>@Localizer["Lost access? Contact admin"]</span>
    </a>
</div>
